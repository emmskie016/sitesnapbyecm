<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Building your site...</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root { --bg: #0B0B0F; --surface: #15151B; --primary: #38BDF8; --ink: #F8FAFC; --ink-soft: #94A3B8; --success: #34D399; }
  *,*::before,*::after { box-sizing: border-box; }
  html,body { margin: 0; padding: 0; height: 100%; }
  body { font-family: 'Inter', -apple-system, system-ui, 'Segoe UI', sans-serif; background: var(--bg); color: var(--ink); display: grid; place-items: center; min-height: 100dvh; line-height: 1.55; font-weight: 400; font-size: 16px; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  .card { background: var(--surface); border-radius: 24px; padding: 60px 52px; max-width: 600px; width: calc(100% - 32px); text-align: center; box-shadow: 0 60px 80px -40px rgba(0,0,0,.6); }
  h1 { margin: 0 0 12px; font-size: 30px; font-weight: 500; letter-spacing: -.025em; line-height: 1.15; }
  p { margin: 0 0 36px; color: var(--ink-soft); font-size: 16px; line-height: 1.6; font-weight: 400; }
  .progress { height: 6px; border-radius: 999px; background: rgba(255,255,255,.07); overflow: hidden; margin-bottom: 20px; }
  .bar { height: 100%; width: 0%; background: linear-gradient(90deg, var(--primary), #818CF8); transition: width .6s cubic-bezier(.2,.8,.2,1); }
  .stage { font-size: 12px; color: var(--ink-soft); margin-bottom: 28px; letter-spacing: .12em; text-transform: uppercase; font-weight: 500; }

  .building { display: block; }
  .building.hide { display: none; }

  .live { display: none; }
  .live.show { display: block; }
  .live .badge { display: inline-flex; align-items: center; gap: 8px; padding: 6px 14px; border-radius: 999px; background: rgba(52,211,153,.12); color: var(--success); font-size: 13px; font-weight: 500; letter-spacing: .02em; margin-bottom: 20px; }
  .live .badge::before { content: ''; width: 8px; height: 8px; border-radius: 999px; background: var(--success); box-shadow: 0 0 12px var(--success); }
  .live h2 { margin: 0 0 12px; font-size: 26px; font-weight: 500; letter-spacing: -.02em; line-height: 1.2; }
  .live .subtitle { margin: 0 0 28px; color: var(--ink-soft); font-size: 16px; line-height: 1.6; }
  .live .url-card { background: rgba(56,189,248,.06); border: 1px solid rgba(56,189,248,.22); border-radius: 14px; padding: 20px; margin: 0 0 24px; word-break: break-all; }
  .live .url-card a { color: var(--primary); font-weight: 500; font-size: 15px; text-decoration: none; }
  .live .url-card a:hover { text-decoration: underline; }
  .visit-btn { display: inline-block; background: var(--primary); color: var(--bg); padding: 14px 28px; border-radius: 999px; font-weight: 600; font-size: 15px; text-decoration: none; letter-spacing: -.005em; transition: transform .15s, box-shadow .2s; margin-bottom: 36px; }
  .visit-btn:hover { transform: translateY(-1px); box-shadow: 0 12px 28px -10px rgba(56,189,248,.5); }
  .contact { border-top: 1px solid rgba(255,255,255,.08); padding-top: 28px; text-align: left; }
  .contact h3 { margin: 0 0 8px; font-size: 16px; font-weight: 500; color: var(--ink); letter-spacing: -.01em; }
  .contact p { margin: 0 0 16px; font-size: 14px; color: var(--ink-soft); line-height: 1.6; }
  .contact a.email-link { display: inline-block; padding: 10px 18px; border: 1px solid rgba(255,255,255,.18); border-radius: 999px; color: var(--ink); text-decoration: none; font-size: 14px; font-weight: 500; transition: border-color .15s, background .15s; }
  .contact a.email-link:hover { border-color: var(--primary); background: rgba(56,189,248,.08); color: var(--primary); }

  .error { display: none; padding: 24px; border: 1px solid rgba(239,68,68,.28); border-radius: 16px; color: #FCA5A5; }
  .error.show { display: block; }
</style>
</head>
<body>
<main class="card">
  <div class="building" id="building">
    <h1>Building your site</h1>
    <p>This usually takes 20–40 seconds. Stay on this page — we'll show your live URL the moment it's ready.</p>
    <div class="progress"><div class="bar" id="bar"></div></div>
    <div class="stage" id="stage">Preparing…</div>
  </div>

  <div class="live" id="live">
    <div class="badge">Live now</div>
    <h2>Your website is live 🎉</h2>
    <p class="subtitle">Your custom site has been built and published. Click below to view it — share the link with anyone.</p>
    <div class="url-card"><a id="liveurl" href="#" target="_blank" rel="noopener">…</a></div>
    <a id="visitbtn" class="visit-btn" href="#" target="_blank" rel="noopener">Visit your site →</a>

    <div class="contact">
      <h3>Need changes or extra features?</h3>
      <p>This is just v1. If you want edits, additional pages, new sections, custom branding, or anything we missed — just send us a message.</p>
      <a class="email-link" href="mailto:{{ contact_email }}?subject=SiteSnap%20edit%20request">Email {{ contact_email }}</a>
    </div>
  </div>

  <div class="error" id="error"></div>
</main>
<script>
  const jobId = "{{ job_id }}";
  const STAGE_LABEL = {
    queued: "Queued…",
    classifying: "Picking a layout…",
    writing_copy: "Writing your copy…",
    fetching_images: "Choosing photography…",
    rendering: "Designing the page…",
    publishing: "Publishing to the web…",
    notifying: "Sending you the link…",
    done: "Done!",
    failed: "Something went wrong",
  };
  async function tick() {
    try {
      const r = await fetch(`/api/jobs/${jobId}`, { cache: "no-store" });
      if (!r.ok) throw new Error("status " + r.status);
      const j = await r.json();
      document.getElementById("bar").style.width = (j.progress_pct || 0) + "%";
      document.getElementById("stage").textContent = STAGE_LABEL[j.status] || j.status;
      if (j.status === "done" && j.site_url) {
        document.getElementById("building").classList.add("hide");
        const live = document.getElementById("live");
        live.classList.add("show");
        const a = document.getElementById("liveurl");
        a.href = j.site_url; a.textContent = j.site_url;
        document.getElementById("visitbtn").href = j.site_url;
        document.title = "Your site is live";
        return;
      }
      if (j.status === "failed") {
        const e = document.getElementById("error");
        e.classList.add("show");
        e.textContent = (j.error && j.error.message) || "Generation failed. We've been notified.";
        return;
      }
    } catch (err) { /* network blip; just keep going */ }
    setTimeout(tick, 2000);
  }
  tick();
</script>
</body>
</html>
